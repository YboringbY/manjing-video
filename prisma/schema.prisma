generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  super_admin
  tenant_admin
  user
}

enum MemberStatus {
  active
  disabled
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  projects    Project[]
  materials   Material[]
  workspaces  ProjectWorkspace[]
  auditLogs   AuditLog[]
  apiProfiles ApiProfile[]
}

model User {
  id           String       @id @default(cuid())
  account      String       @unique
  passwordHash String
  displayName  String
  email        String?
  phone        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  createdProjects Project[] @relation("ProjectCreatedBy")
  updatedProjects Project[] @relation("ProjectUpdatedBy")
  materials    Material[]
  workspaces   ProjectWorkspace[]
  auditLogs    AuditLog[]
}

model Membership {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  role      MemberRole
  status    MemberStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model Project {
  id            Int      @id
  tenantId      String
  name          String
  type          String   @default("AI 漫剧")
  script        String   @default("")
  status        String   @default("active")
  createdById   String?
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?    @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  shots         Shot[]
  videoTasks    VideoTask[]
  videoAssets   VideoAsset[]

  @@index([tenantId, updatedAt])
  @@index([createdById])
  @@index([updatedById])
}

model Shot {
  id         BigInt
  tenantId   String
  projectId  Int
  title      String
  prompt     String
  ratio      String
  duration   Int
  status     String   @default("pending")
  resolution String?
  width      Int?
  height     Int?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([tenantId, projectId, id])
  @@index([tenantId, projectId, sortOrder])
  @@index([tenantId, status])
}

model VideoTask {
  id             String
  tenantId       String
  projectId      Int
  shotId         BigInt
  shotTitle      String
  provider       String
  status         String   @default("pending")
  result         String
  providerTaskId String?
  apiProfileId   String?
  snapshot       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([tenantId, projectId, id])
  @@index([tenantId, projectId, updatedAt])
  @@index([tenantId, status])
  @@index([providerTaskId])
}

model VideoAsset {
  id             BigInt
  tenantId       String
  projectId      Int
  shotId         BigInt
  title          String
  meta           String
  gradient       String
  videoUrl       String?
  providerTaskId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([tenantId, projectId, id])
  @@index([tenantId, projectId, updatedAt])
  @@index([tenantId, shotId])
  @@index([providerTaskId])
}

model Material {
  id                Int      @id @default(autoincrement())
  tenantId          String
  projectId         Int
  name              String
  kind              String
  role              String
  url               String
  previewUrl        String?
  storagePath       String?
  seedanceAssetUrl  String?
  reviewedAssetUrl  String?
  width             Int?
  height            Int?
  source            String   @default("upload")
  status            String   @default("ready")
  scope             String   @default("project")
  prompt            String?
  sourceProjectId   Int?
  sourceProjectName String?
  createdById       String?
  createdByName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy         User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, scope, createdAt])
  @@index([createdById])
}

model ProjectWorkspace {
  id            Int      @id @default(autoincrement())
  tenantId      String
  projectId     Int
  name          String
  state         Json
  updatedById   String?
  updatedByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy     User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, projectId])
  @@index([tenantId, updatedAt])
  @@index([updatedById])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  tenantId     String?
  userId       String?
  actorAccount String?
  action       String
  targetType   String
  targetId     String?
  result       String   @default("success")
  ip           String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model ApiProfile {
  id                String   @id
  tenantId          String
  name              String
  baseUrl           String
  encryptedApiKey   String
  model             String?
  textModels        Json
  scriptModels      Json?
  videoModels       Json
  imageModels       Json
  priority          Int      @default(100)
  enabled           Boolean  @default(true)
  concurrencyLimit  Int      @default(1)
  active            Boolean  @default(false)
  createdAtMillis   BigInt?
  updatedAtMillis   BigInt?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, baseUrl])
  @@index([tenantId, active])
  @@index([tenantId, enabled, priority])
}
