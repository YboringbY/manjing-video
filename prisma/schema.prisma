generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  super_admin
  tenant_admin
  user
}

enum MemberStatus {
  active
  disabled
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  materials   Material[]
}

model User {
  id           String       @id @default(cuid())
  account      String       @unique
  passwordHash String
  displayName  String
  email        String?
  phone        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  materials    Material[]
}

model Membership {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  role      MemberRole
  status    MemberStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model Material {
  id                Int      @id @default(autoincrement())
  tenantId          String
  projectId         Int
  name              String
  kind              String
  role              String
  url               String
  previewUrl        String?
  storagePath       String?
  seedanceAssetUrl  String?
  reviewedAssetUrl  String?
  source            String   @default("upload")
  status            String   @default("ready")
  scope             String   @default("project")
  prompt            String?
  sourceProjectId   Int?
  sourceProjectName String?
  createdById       String?
  createdByName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy         User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, createdAt])
  @@index([tenantId, scope, createdAt])
  @@index([createdById])
}
